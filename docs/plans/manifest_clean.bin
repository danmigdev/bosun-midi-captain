{"id": "CLEAN1", "type": "MANIFEST", "core_messages": {"note_off": {"summary": "Note Off {note} ch {channel}", "label": "Note Off", "params": {"note": {"min": 0, "default": 60, "type": "int", "max": 127, "label": "Note"}, "velocity": {"min": 0, "default": 64, "type": "int", "max": 127, "label": "Velocity"}, "channel": {"min": 1, "default": 1, "type": "int", "max": 16, "label": "Channel"}}}, "delay": {"summary": "Wait {ms}ms", "label": "Delay", "params": {"ms": {"min": 0, "default": 100, "type": "int", "max": 5000, "label": "Milliseconds"}}}, "pc": {"summary": "PC {program} ch {channel}", "label": "Program Change", "params": {"channel": {"min": 1, "default": 1, "type": "int", "max": 16, "label": "Channel"}, "program": {"min": 0, "default": 0, "type": "int", "max": 127, "label": "Program"}}}, "note_on": {"summary": "Note On {note} v{velocity} ch {channel}", "label": "Note On", "params": {"note": {"min": 0, "default": 60, "type": "int", "max": 127, "label": "Note"}, "velocity": {"min": 0, "default": 100, "type": "int", "max": 127, "label": "Velocity"}, "channel": {"min": 1, "default": 1, "type": "int", "max": 16, "label": "Channel"}}}, "cc": {"summary": "CC {cc}={value} ch {channel}", "label": "Control Change", "params": {"value": {"min": 0, "default": 0, "type": "int", "max": 127, "label": "Value"}, "cc": {"min": 0, "default": 0, "type": "int", "max": 127, "label": "CC #"}, "channel": {"min": 1, "default": 1, "type": "int", "max": 16, "label": "Channel"}}}}, "plugins": {"ampero_ii_stage": {"messages": {"ampero_engage": {"summary": "{state}", "label": "Engage / Bypass", "params": {"state": {"label": "State", "type": "enum", "values": ["engage", "analog_bypass", "dsp_bypass"], "default": "engage"}, "channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}}}, "ampero_scene": {"summary": "Scene {scene}", "label": "Scene", "params": {"channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}, "scene": {"min": 1, "default": 1, "type": "int", "max": 5, "label": "Scene"}}}, "ampero_qa_param": {"summary": "QA{param} {action}", "label": "Quick Access Param", "params": {"value": {"if": {"action": "set"}, "type": "int", "min": 0, "max": 127, "default": 64, "label": "Value"}, "channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}, "param": {"label": "Param", "type": "enum", "values": [1, 2, 3], "default": 1}, "action": {"label": "Action", "type": "enum", "values": ["step_up", "step_down", "set"], "default": "step_up"}}}, "ampero_tuner": {"summary": "Tuner {state}", "label": "Tuner", "params": {"state": {"label": "State", "type": "enum", "values": ["on", "off"], "default": "on"}, "channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}}}, "ampero_slot_toggle": {"summary": "Slot {slot} {value}", "label": "Effect Slot On/Off", "params": {"slot": {"label": "Slot", "type": "enum", "values": ["B6", "A1", "A2", "A3", "B3", "B2", "B1", "B4", "A4", "A5", "A6", "B5"], "default": "A1"}, "value": {"label": "Value", "type": "enum", "values": ["on", "off"], "default": "on"}, "channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}}}, "ampero_patch": {"summary": "Patch {patch}", "label": "Select Patch (P##-#)", "params": {"channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}, "patch": {"label": "Patch", "type": "string", "pattern": "^P[0-6][0-9]-[1-5]$", "default": "P01-1"}}}, "ampero_looper": {"summary": "Looper {action}", "label": "Looper", "params": {"channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}, "action": {"label": "Action", "type": "enum", "values": ["normal_speed", "overdub", "stop", "undo", "forward", "pre_post", "chain_ab", "play", "clear", "rec", "half_speed", "redo", "reverse"], "default": "rec"}}}, "ampero_tap_tempo": {"summary": "Tap", "label": "Tap Tempo", "params": {"channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}}}, "ampero_set_tempo": {"summary": "BPM {bpm}", "label": "Set BPM", "params": {"bpm": {"min": 40, "default": 120, "type": "int", "max": 300, "label": "BPM"}, "channel": {"min": 1, "default": 16, "type": "int", "max": 16, "label": "Channel"}}}}, "label": "Hotone Ampero II Stage", "version": "1.0"}}}
