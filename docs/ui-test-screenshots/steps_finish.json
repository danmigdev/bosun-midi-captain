  {"do":"click","sel":".scalebtn:nth-child(3)"},
  {"do":"click","sel":".scalebtn:nth-child(3)"},
  {"do":"click","sel":".scalebtn:nth-child(3)"},
  {"do":"click","sel":".scalebtn:nth-child(3)"},
