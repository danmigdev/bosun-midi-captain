{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bosun",
  "version": "0.4.13",
  "identifier": "com.bosun.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bosun",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "shortDescription": "Editor for PaintAudio MIDI Captain controllers running Bosun firmware.",
    "longDescription": "Desktop editor for PaintAudio MIDI Captain controllers running Bosun firmware, with a plugin system for any MIDI target device (Kemper Player, Hotone Ampero II Stage, Line 6 Helix, generic MIDI, and more).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/circuitpython.uf2": "circuitpython.uf2",
      "resources/firmware": "firmware",
      "resources/lib": "lib"
    }
  }
}
